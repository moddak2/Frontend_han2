{
  "name": "frontend_han2",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "desktop": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build": "tsc -b && vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win portable",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.frontendhan2.desktop",
    "productName": "Frontend Han2",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    }
  }
}